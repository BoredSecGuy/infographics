{
  "buildCommand": null,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/missouri-tax-shift", "destination": "/missouri-tax-shift/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    }
  ]
}
